{
    "name": "wizballesy/librenms-quick-search",
    "description": "Adds lightweight quick search fields to selected LibreNMS pages.",
    "type": "package",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "WizballEsy\\LibreNmsQuickSearch\\": "src/",
            "WizballEsy\\LibreNmsQuickSearch\\Hooks\\": "hooks/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WizballEsy\\LibreNmsQuickSearch\\QuickSearchServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.2",
        "librenms/plugin-interfaces": "^1.0"
    }
}
